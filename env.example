# .env — copia este archivo como ".env" en la raíz del proyecto y completa los valores.
# NUNCA subas el .env real a git (agrega ".env" a tu .gitignore si no está ya).

# ── Supabase — Project Settings > API en el dashboard de tu proyecto ──────────

# "Project URL"
SUPABASE_URL=https://TU-PROYECTO.supabase.co

# "anon public" key (empieza con eyJ...) — esta SÍ puede ir expuesta al navegador,
# está diseñada para eso, la seguridad real la hace RLS.
SUPABASE_KEY=

# "service_role" key (también empieza con eyJ..., es OTRA clave, no la confundas
# con la anon). Esta bypassea RLS por completo — NUNCA debe llegar al navegador.
# Se usa solo en server/api/* (server-side de Nuxt) y en scripts/seed-usuarios.mjs.
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n (para el endpoint que recibe eventos de WhatsApp) ─────────────────────
# Inventa un string largo random, y pon el mismo valor en el header que
# configures en el nodo HTTP Request de n8n que llama a /api/n8n/whatsapp-event
N8N_WEBHOOK_SECRET=

# ── Kame ERP (cuando conectes el proxy de solo lectura) ───────────────────────
# Todavía no construimos el server/api/kame/ real con estas credenciales -
# déjalas vacías por ahora, las llenamos cuando lleguemos a esa parte.
KAME_API_BASE_URL=
KAME_API_USER=
KAME_API_PASSWORD=
